# Seashell Desk — example environment. Copy to src/.env (gitignored) and fill in.

# ── Required ────────────────────────────────────────────────────────────────

# Anthropic API key. The runner uses Claude for all agent reasoning.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Google (Gmail + Calendar) ───────────────────────────────────────────────
# Needed only if you want the Gmail sync and Calendar tools. You can either
# set these two env vars, or drop the OAuth client JSON at
# .credentials/gmail-oauth-client.json (see the Google Cloud Console OAuth
# setup). First auth run writes .credentials/google-token.json — run
# `bun run auth` to (re)authorize.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Gemini (document scanning) ──────────────────────────────────────────────
# Optional. When present, the camera/scanner pipeline can ask Gemini to
# auto-detect document corners before perspective correction. Without it,
# the scanner falls back to manual bounds.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=60000
# GEMINI_PREFLIGHT_TIMEOUT_MS=15000

# ── Server ──────────────────────────────────────────────────────────────────
# Port for `bun run desk` (web UI + WebSocket). Defaults to 4312.
# DESK_PORT=4312
