{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"]
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
